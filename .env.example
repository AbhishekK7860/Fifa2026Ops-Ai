# ==============================================================================
# StadiumOps AI — Environment Variables
# ==============================================================================
# All variables below are OPTIONAL.
# The application runs fully in Offline Analysis Mode when none are configured.
# Offline Mode uses deterministic rule-based analysis and produces the same
# output schema as the AI-powered mode — no functionality is lost.
# ==============================================================================

# --- AI Provider (OpenRouter) ---
# Used for AI-powered crowd analysis. When absent, Offline Analysis Mode
# activates automatically. No hard failure — the app remains fully usable.
#
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Supabase (Optional — Anonymous Audit Logging Only) ---
# Used to log anonymous upload metadata (filename, row count, timestamp).
# NO personal data, NO user table, NO authentication.
# When absent, audit logging is silently skipped — the app is unaffected.
#
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
